# SMTP settings so OTP codes are actually emailed.
#
# 1. Copy this file to `.env` in the same folder:   cp .env.example .env
# 2. Fill in your details below.
# 3. Start the backend with:                        ./run-with-mail.sh
#
# `.env` is gitignored — never commit your real password.
#
# --- Gmail ---
# You CANNOT use your normal Gmail password. You must:
#   a) turn on 2-Step Verification on your Google account, then
#   b) create an App Password at https://myaccount.google.com/apppasswords
#      (choose "Mail" / "Other") and paste the 16-character code below.

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your.address@gmail.com
MAIL_PASSWORD=your16charapppassword
MAIL_FROM=your.address@gmail.com
